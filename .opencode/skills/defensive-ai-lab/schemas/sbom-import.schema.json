{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/defensive-ai-lab/sbom-import.schema.json",
  "title": "Normalized SBOM Import",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "source_type", "format", "imported_at", "components"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "case_id": { "type": "string", "format": "uuid" },
    "source_type": { "const": "user_artifact" },
    "format": { "enum": ["cyclonedx", "spdx", "syft", "generic"] },
    "imported_at": { "type": "string", "format": "date-time" },
    "input_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "ecosystem": { "enum": ["npm", "pypi", "maven", "go", "cargo", "composer", "gem", "nuget", "generic"] },
          "purl": { "type": "string" },
          "license": { "type": "string" },
          "supplier": { "type": "string" },
          "scope": { "enum": ["required", "optional", "excluded"] }
        }
      }
    }
  }
}
