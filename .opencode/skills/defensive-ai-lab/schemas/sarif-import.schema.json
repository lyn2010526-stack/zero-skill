{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/defensive-ai-lab/sarif-import.schema.json",
  "title": "Normalized SARIF Import",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "source_type", "tool", "imported_at", "results"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "case_id": { "type": "string", "format": "uuid" },
    "source_type": { "const": "user_artifact" },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "sarif_version": { "type": "string" }
      }
    },
    "imported_at": { "type": "string", "format": "date-time" },
    "input_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "level", "message", "location"],
        "properties": {
          "rule_id": { "type": "string" },
          "level": { "enum": ["none", "note", "warning", "error"] },
          "message": { "type": "string", "maxLength": 2000 },
          "location": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "start_line": { "type": "integer", "minimum": 1 },
              "end_line": { "type": "integer", "minimum": 1 },
              "snippet_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          },
          "cwe": { "type": "string", "pattern": "^CWE-\\d+$" },
          "cvss_vector": { "type": "string" }
        }
      }
    }
  }
}
