{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/defensive-ai-lab/checkpoint.schema.json",
  "title": "Case Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "revision", "state", "manifest_sha256", "completed_steps", "pending_steps", "artifacts", "updated_at"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "case_id": { "type": "string", "format": "uuid" },
    "revision": { "type": "integer", "minimum": 1 },
    "state": { "enum": ["created", "scoped", "planned", "running", "paused", "validating", "completed", "blocked"] },
    "manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "completed_steps": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" }, "uniqueItems": true },
    "pending_steps": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" }, "uniqueItems": true },
    "artifacts": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
    "evidence_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "claim_ids": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
