{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/defensive-ai-lab/classification.schema.json",
  "title": "Finding Classification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "finding_id", "cwe", "owasp_category", "cvss"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "finding_id": { "type": "string", "pattern": "^F-[A-Z0-9-]{4,64}$" },
    "cwe": { "type": "string", "pattern": "^CWE-\\d+$" },
    "owasp_category": { "type": "string", "pattern": "^A0[1-9](:[A-Za-z0-9 -]+)?$" },
    "cvss": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vector", "base_score", "severity"],
      "properties": {
        "vector": { "type": "string", "minLength": 1 },
        "base_score": { "type": "number", "minimum": 0, "maximum": 10 },
        "severity": { "enum": ["none", "low", "medium", "high", "critical"] }
      }
    },
    "owasp_mobile_category": { "type": "string", "pattern": "^M[1-9][0-9]?(:[A-Za-z0-9 -]+)?$" },
    "confidence": { "enum": ["high", "medium", "low"] },
    "reachability": { "enum": ["confirmed-reachable", "static-trace", "unknown"] }
  }
}
