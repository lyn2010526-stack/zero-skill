{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/defensive-ai-lab/approval-record.schema.json",
  "title": "Human Approval Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "approval_id", "case_id", "request", "requested_by", "decided_at", "decision"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "approval_id": { "type": "string", "pattern": "^AP-[A-Z0-9-]{4,64}$" },
    "case_id": { "type": "string", "format": "uuid" },
    "request": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "justification": { "type": "string", "maxLength": 2000 },
    "requested_by": { "enum": ["agent", "user", "system"] },
    "approved_by": { "type": "string" },
    "decided_at": { "type": "string", "format": "date-time" },
    "decision": { "enum": ["approved", "rejected", "deferred"] },
    "conditions": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "audit_event": { "enum": ["claim_accepted", "claim_rejected", "case_blocked", "checkpoint_written"] }
  }
}
