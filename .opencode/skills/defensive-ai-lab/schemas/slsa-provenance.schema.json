{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/defensive-ai-lab/slso-provenance.schema.json",
  "title": "SLSA Provenance Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "build_type", "builder", "materials", "subject"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "case_id": { "type": "string", "format": "uuid" },
    "build_type": { "type": "string", "minLength": 1 },
    "builder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["uri", "digest"],
        "properties": {
          "uri": { "type": "string" },
          "digest": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      }
    },
    "subject": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "digest"],
        "properties": {
          "name": { "type": "string" },
          "digest": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      }
    },
    "slsa_level": { "enum": ["L1", "L2", "L3", "L4"] },
    "generated_at": { "type": "string", "format": "date-time" }
  }
}
