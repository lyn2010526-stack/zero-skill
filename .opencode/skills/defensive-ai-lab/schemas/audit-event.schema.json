{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/defensive-ai-lab/audit-event.schema.json",
  "title": "Audit Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sequence", "case_id", "timestamp", "event", "metadata", "previous_hash", "event_hash"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "sequence": { "type": "integer", "minimum": 1 },
    "case_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "event": { "enum": ["case_created", "scope_checked", "plan_written", "tool_started", "tool_finished", "claim_accepted", "claim_rejected", "artifact_redacted", "checkpoint_written", "report_exported", "case_blocked", "case_completed"] },
    "metadata": { "type": "object" },
    "previous_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "event_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
