{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/defensive-ai-lab/experiment.schema.json",
  "title": "AI Experiment Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "hypothesis", "prompt_sha256", "dataset_sha256", "models", "parameter_grid", "limits", "evaluation"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "case_id": { "type": "string", "format": "uuid" },
    "hypothesis": { "type": "string", "minLength": 1 },
    "prompt_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "dataset_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "models": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
    "parameter_grid": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "array", "minItems": 1 } },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_runs", "max_retries", "concurrency", "timeout_seconds"],
      "properties": {
        "max_runs": { "type": "integer", "minimum": 1 },
        "max_retries": { "type": "integer", "minimum": 0, "maximum": 5 },
        "concurrency": { "type": "integer", "minimum": 1, "maximum": 4 },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 1800 },
        "max_input_tokens": { "type": "integer", "minimum": 1 },
        "max_output_tokens": { "type": "integer", "minimum": 1 },
        "max_cost": { "type": "number", "minimum": 0 }
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rubric_version", "deterministic_assertions"],
      "properties": {
        "rubric_version": { "type": "string" },
        "deterministic_assertions": { "type": "array", "items": { "type": "string" } },
        "judge_alias": { "type": "string" },
        "human_review": { "type": "boolean" }
      }
    }
  }
}
