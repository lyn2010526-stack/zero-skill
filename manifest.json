{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "name": "zero_apex",
  "version": "3.0.0",
  "description": "ZeroApex 精简版 — 只做三件事：命令安全解析 + 文件保护 + 执行审计。不假装能防 AI 闯祸。",
  "compatibility": "Operit AI / QuickJS Sandbox",
  "license": "Apache-2.0",
  "language": "zh-CN",
  "entrypoint": "engine/zero_apex.js",
  "skill_file": "零.skill",
  "tools": [
    {
      "name": "file_guard",
      "layer": "文件保护",
      "requires": [],
      "min_permission": "none",
      "triggers": ["command_risk"],
      "blocking": true,
      "description": "检测删除/覆盖命令和危险路径，返回风险等级和是否需要确认"
    },
    {
      "name": "shell_guard",
      "layer": "命令解析",
      "requires": [],
      "min_permission": "none",
      "triggers": ["command_exec"],
      "blocking": true,
      "description": "命令分段解析 + 读写白名单，BLOCK/ASK/ALLOW 三级判定"
    },
    {
      "name": "normalize_command",
      "layer": "命令解析",
      "requires": [],
      "min_permission": "none",
      "triggers": ["command_input"],
      "blocking": false,
      "description": "解码命令混淆（hex/unicode/octal 迭代解码，最多3层嵌套）"
    },
    {
      "name": "snapshot_backup",
      "layer": "文件保护",
      "requires": ["Files"],
      "min_permission": "write",
      "triggers": ["file_delete", "file_write"],
      "blocking": false,
      "description": "文件操作前自动备份到 .trash，支持墓碑机制"
    },
    {
      "name": "snapshot_restore",
      "layer": "文件保护",
      "requires": ["Files"],
      "min_permission": "write",
      "triggers": ["file_restore"],
      "blocking": false,
      "description": "从 .trash 恢复文件到原始路径"
    },
    {
      "name": "audit_log",
      "layer": "审计",
      "requires": [],
      "min_permission": "none",
      "triggers": ["manual"],
      "blocking": false,
      "description": "查看最近的执行审计日志"
    }
  ],
  "references": [
    {
      "name": "file_guard",
      "path": "references/file_guard.md",
      "layer": "文件保护",
      "priority": "critical",
      "min_permission": "none",
      "triggers": ["command_risk:destructive"]
    },
    {
      "name": "shell_guard",
      "path": "references/shell_guard.md",
      "layer": "命令解析",
      "priority": "critical",
      "min_permission": "none",
      "triggers": ["command_exec"]
    },
    {
      "name": "snapshot",
      "path": "references/snapshot.md",
      "layer": "文件保护",
      "priority": "high",
      "min_permission": "write",
      "triggers": ["file_delete", "file_write"]
    }
  ],
  "sandbox": {
    "allowed_commands": ["ls", "cat", "head", "tail", "grep", "find", "wc", "file", "stat", "which", "echo", "pwd", "whoami", "date", "env", "printenv", "git status", "git log", "git diff"],
    "blocked_commands": ["rm -rf /", "chmod 777", "mkfs", "fdisk", "dd if=/dev/zero"],
    "protected_paths": ["/etc", "/usr", "/bin", "/sbin", "/boot", "/sys", "/proc", "/dev", "C:\\Windows"]
  },
  "permission": {
    "default": "allow",
    "rules": [
      { "match": "rm -rf /*", "verdict": "block", "reason": "危险删除命令" },
      { "match": "chmod 777 /etc/*", "verdict": "block", "reason": "危险权限设置" },
      { "match": "DROP TABLE", "verdict": "ask", "reason": "数据库破坏性操作" }
    ]
  }
}
