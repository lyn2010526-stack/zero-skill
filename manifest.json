{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "name": "zero_apex",
  "version": "2.5.8",
  "description": "首席工程师执行引擎。守护层为可执行 JS，运行在 Operit QuickJS 沙箱。",
  "compatibility": "Operit AI",
  "license": "Apache-2.0",
  "language": "zh-CN",
  "entrypoint": "engine/zero_apex.js",
  "skill_file": "零.skill",
  "min_operit_version": ">=1.0",
  "requires_tools": ["Files", "Network", "Tools.Memory"],
  "optional_tools": ["Files.listFiles", "Files.exists"],
  "env_requirements": {
    "min_permission_level": "basic",
    "permission_levels": {
      "none": {
        "description": "仅纯文本应答，无文件/网络/工具访问",
        "tools_disabled": ["Files", "Network", "Tools.Memory"],
        "references_disabled": ["file_guard", "snapshot", "open_source", "memory"]
      },
      "basic": {
        "description": "Files.read/write（沙箱目录内），无网络无记忆",
        "tools_enabled": ["Files.read", "Files.write", "Files.exists"],
        "tools_disabled": ["Network", "Tools.Memory"],
        "references_disabled": ["open_source", "memory"]
      },
      "network": {
        "description": "L1 + 网络访问",
        "tools_enabled": ["Files", "Network.httpGet"],
        "tools_disabled": ["Tools.Memory"],
        "references_disabled": ["memory"]
      },
      "shell": {
        "description": "L2 + shell 命令执行（非 root）",
        "tools_enabled": ["Files", "Network", "Shell"]
      },
      "shizuku": {
        "description": "L3 + Shizuku 提权",
        "tools_enabled": ["Files", "Network", "Shell", "Shizuku"],
        "flag": "android.shizuku_available"
      },
      "root": {
        "description": "L4 + root 权限",
        "tools_enabled": ["Files", "Network", "Shell", "Shizuku", "Root"]
      }
    }
  },
  "tools": [
    {
      "name": "preflight",
      "layer": "综合",
      "requires": [],
      "min_permission": "none",
      "triggers": ["task_type:engineering", "command_risk:destructive"],
      "blocking": true,
      "description": "执行前四层门禁串联，返回 allowed/state/reasons"
    },
    {
      "name": "file_guard",
      "layer": "防删",
      "requires": [],
      "min_permission": "none",
      "triggers": ["command_risk:destructive", "keywords:删除/覆盖/截断"],
      "blocking": true,
      "description": "分析命令/脚本/路径的删除风险"
    },
    {
      "name": "hallucination_guard",
      "layer": "防幻觉",
      "requires": [],
      "min_permission": "none",
      "triggers": ["output:技术断言", "output:完成声明"],
      "blocking": true,
      "description": "检测幻觉违规，返回修正建议"
    },
    {
      "name": "evidence_check",
      "layer": "证据",
      "requires": [],
      "min_permission": "none",
      "triggers": ["claim:完成/搞定/编译通过"],
      "blocking": true,
      "description": "判定完成声明的验证等级 L0-L6"
    },
    {
      "name": "self_monitor",
      "layer": "自检",
      "requires": [],
      "min_permission": "none",
      "triggers": ["task_start"],
      "blocking": false,
      "description": "六维元状态评估"
    },
    {
      "name": "output_firewall",
      "layer": "防火墙",
      "requires": [],
      "min_permission": "none",
      "triggers": ["before_user_output"],
      "blocking": true,
      "description": "检测输出中的六类违规"
    },
    {
      "name": "search_opensource",
      "layer": "开源",
      "requires": ["Network"],
      "min_permission": "network",
      "triggers": ["keywords:搜索/对比/融合"],
      "blocking": false,
      "description": "真实 GitHub API 搜索"
    },
    {
      "name": "remember",
      "layer": "记忆",
      "requires": ["Tools.Memory"],
      "min_permission": "basic",
      "triggers": ["task_complete", "task_failed"],
      "blocking": false,
      "description": "写入持久化记忆"
    },
    {
      "name": "recall",
      "layer": "记忆",
      "requires": ["Tools.Memory"],
      "min_permission": "basic",
      "triggers": ["keywords:经验/上次/类似"],
      "blocking": false,
      "description": "检索历史经验"
    },
    {
      "name": "snapshot_file",
      "layer": "快照",
      "requires": ["Files"],
      "min_permission": "basic",
      "triggers": ["command_risk:destructive"],
      "blocking": false,
      "description": "备份文件到 .trash"
    },
    {
      "name": "restore_file",
      "layer": "快照",
      "requires": ["Files"],
      "min_permission": "basic",
      "triggers": ["keywords:恢复/误删"],
      "blocking": false,
      "description": "从 .trash 恢复文件"
    },
    {
      "name": "snapshot_cleanup",
      "layer": "快照",
      "requires": ["Files"],
      "min_permission": "basic",
      "triggers": ["periodic", "manual"],
      "blocking": false,
      "description": "清理过期快照：超过 max_age_hours（默认 24h）或超过 max_count（默认 50 个）时删除最旧快照",
      "added_in": "2.4.0"
    },
    {
      "name": "tombstone_file",
      "layer": "快照",
      "requires": ["Files"],
      "min_permission": "basic",
      "triggers": ["keywords:删除/逻辑删除"],
      "blocking": false,
      "description": "逻辑删除：Files.delete 不可用时先备份再覆盖为墓碑标记（含恢复指针），可调用 restore_file 恢复",
      "added_in": "2.5.3"
    },
    {
      "name": "enforce_block",
      "layer": "强制拦截",
      "requires": [],
      "min_permission": "none",
      "triggers": ["preflight:BLOCK"],
      "blocking": true,
      "description": "引擎层硬阻断：preflight 返回 BLOCK 时强制终止后续工具执行",
      "added_in": "2.2.0"
    },
    {
      "name": "audit_log",
      "layer": "调试",
      "requires": ["Files"],
      "min_permission": "basic",
      "triggers": ["every_tool_call"],
      "blocking": false,
      "description": "记录每次工具调用的触发原因/耗时/结果/task_id 到 audit_log.jsonl",
      "added_in": "2.2.0"
    },
    {
      "name": "evaluate_permission",
      "layer": "权限",
      "requires": [],
      "min_permission": "none",
      "triggers": ["before_tool_exec"],
      "blocking": true,
      "description": "按 deny>ask>allow 规则评估工具调用，default 模式下未匹配走 preflight 现有逻辑",
      "added_in": "2.3.0"
    },
    {
      "name": "check_sandbox",
      "layer": "沙箱",
      "requires": [],
      "min_permission": "none",
      "triggers": ["path_write", "command_exec"],
      "blocking": true,
      "description": "按 sandbox profile（workspace/read-only/strict）校验可写路径与可执行命令",
      "added_in": "2.3.0"
    },
    {
      "name": "config_get",
      "layer": "配置",
      "requires": [],
      "min_permission": "none",
      "triggers": ["manual"],
      "blocking": false,
      "description": "读取运行时配置项（如 snapshot.cleanup TTL/容量），不传 key 返回全部配置",
      "added_in": "2.5.0"
    },
    {
      "name": "config_set",
      "layer": "配置",
      "requires": [],
      "min_permission": "basic",
      "triggers": ["manual"],
      "blocking": false,
      "description": "运行时修改配置项（如 snapshot.cleanup.max_age_hours=720）",
      "added_in": "2.5.0"
    },
    {
      "name": "reasoning_chain",
      "layer": "推理",
      "requires": [],
      "min_permission": "none",
      "triggers": ["task_start", "task_type:engineering"],
      "blocking": false,
      "description": "ReAct 风格推理链：记录 Thought/Action/Observation/Reflection 步骤，为 preflight 提供可验证的推理上下文",
      "added_in": "2.5.8"
    },
    {
      "name": "task_plan",
      "layer": "规划",
      "requires": [],
      "min_permission": "none",
      "triggers": ["task_type:complex", "keywords:分解/规划/子任务"],
      "blocking": false,
      "description": "层次化任务分解：将复杂 goal 拆解为带依赖关系的 DAG 子任务树，支持并行就绪节点检测和失败传播",
      "added_in": "2.5.8"
    },
    {
      "name": "reflexion",
      "layer": "反思",
      "requires": [],
      "min_permission": "none",
      "triggers": ["task_failed", "task_complete"],
      "blocking": false,
      "description": "Reflexion 反思引擎：失败后提取结构化经验规则，注入后续 preflight 上下文，防止重复犯同类错误",
      "added_in": "2.5.8"
    }
  ],
  "references": [
    {
      "name": "file_guard",
      "path": "references/file_guard.md",
      "layer": "防删",
      "priority": "critical",
      "min_permission": "none",
      "triggers": ["command_risk:destructive"],
      "conflicts_with": []
    },
    {
      "name": "hallucination_guard",
      "path": "references/hallucination_guard.md",
      "layer": "防幻觉",
      "priority": "critical",
      "min_permission": "none",
      "triggers": ["output:技术断言", "output:完成声明"],
      "conflicts_with": []
    },
    {
      "name": "evidence_verifier",
      "path": "references/evidence_verifier.md",
      "layer": "证据",
      "priority": "critical",
      "min_permission": "none",
      "triggers": ["claim:完成"],
      "conflicts_with": []
    },
    {
      "name": "self_monitor",
      "path": "references/self_monitor.md",
      "layer": "自检",
      "priority": "high",
      "min_permission": "none",
      "triggers": ["task_start"],
      "conflicts_with": []
    },
    {
      "name": "output_firewall",
      "path": "references/output_firewall.md",
      "layer": "防火墙",
      "priority": "critical",
      "min_permission": "none",
      "triggers": ["before_user_output"],
      "conflicts_with": []
    },
    {
      "name": "open_source",
      "path": "references/open_source.md",
      "layer": "开源",
      "priority": "normal",
      "min_permission": "network",
      "triggers": ["keywords:搜索/对比/融合"],
      "conflicts_with": []
    },
    {
      "name": "memory",
      "path": "references/memory.md",
      "layer": "记忆",
      "priority": "high",
      "min_permission": "basic",
      "triggers": ["task_complete", "task_failed"],
      "conflicts_with": []
    },
    {
      "name": "snapshot",
      "path": "references/snapshot.md",
      "layer": "快照",
      "priority": "critical",
      "min_permission": "basic",
      "triggers": ["command_risk:destructive"],
      "conflicts_with": []
    },
    {
      "name": "preflight",
      "path": "references/preflight.md",
      "layer": "综合",
      "priority": "critical",
      "min_permission": "none",
      "triggers": ["task_type:engineering"],
      "conflicts_with": []
    },
    {
      "name": "operit_capabilities",
      "path": "references/operit_capabilities.md",
      "layer": "权限",
      "priority": "high",
      "min_permission": "none",
      "triggers": ["tool_error", "permission_check"],
      "conflicts_with": []
    },
    {
      "name": "evolution",
      "path": "references/evolution.md",
      "layer": "进化",
      "priority": "normal",
      "min_permission": "basic",
      "triggers": ["task_complete:batch", "manual:evolve"],
      "conflicts_with": [],
      "added_in": "2.2.0"
    }
  ],
  "deactivates_on": [
    "task_type:chat",
    "task_type:greeting",
    "task_type:weather",
    "task_type:sentiment",
    "task_type:quick_qa",
    "task_type:browse_only",
    "signal:user_explicit_simple_answer",
    "signal:no_code_or_command_involved"
  ],
  "evolution": {
    "enabled": true,
    "script": "scripts/evolve.js",
    "log_path": ".zero_apex/evolution_log.jsonl",
    "min_failures_to_trigger": 3,
    "auto_merge": true,
    "auto_test": true,
    "backup_before_merge": true
  },
  "audit": {
    "enabled": true,
    "log_path": ".zero_apex/audit_log.jsonl",
    "fields": ["timestamp", "tool", "task_id", "trigger", "duration_ms", "result_code", "result_summary"]
  },
  "sandbox": {
    "default_profile": "workspace",
    "profiles": {
      "workspace": {
        "description": "仅允许 .zero_apex/ 工作目录写文件，其他路径需显式 allow",
        "writable_paths": [".zero_apex/**", ".trash/**"],
        "readable_paths": ["*"],
        "executable_commands": ["*"],
        "deny_paths": ["/proc/**", "/sys/**", "/dev/**", "/etc/shadow", "/etc/passwd"]
      },
      "read-only": {
        "description": "默认禁止一切写操作，所有写都需 manifest 显式 allow",
        "writable_paths": [],
        "readable_paths": ["*"],
        "executable_commands": ["ls", "cat", "pwd", "date", "whoami", "hostname", "uptime", "ps", "head", "tail", "wc", "sort", "uniq", "tr", "cut", "grep", "rg", "git status", "git branch", "git log", "git diff", "git show", "git rev-parse", "kubectl get", "kubectl logs", "kubectl describe", "cargo check"],
        "deny_paths": ["**"]
      },
      "strict": {
        "description": "最严格：所有写、执行、网络均需 manifest 显式 allow，read-only 命令集 + 路径白名单",
        "writable_paths": [],
        "readable_paths": [".zero_apex/**"],
        "executable_commands": ["ls", "cat", "pwd"],
        "deny_paths": ["**"]
      }
    },
    "dangerous_commands": ["rm", "rmdir", "unlink", "shred", "chmod", "chown", "chgrp", "chattr", "pkill", "kill", "killall", "git push", "shutdown", "reboot", "poweroff", "init", "mkfs", "fdisk", "parted", "mount", "umount", "iptables", "ip6tables", "nft", "ufw", "firewall-cmd", "useradd", "userdel", "usermod", "passwd", "visudo", "chroot", "sudo", "su"]
  },
  "permission": {
    "default_mode": "default",
    "modes": {
      "default": "未匹配规则的调用走 preflight 现有逻辑",
      "dontAsk": "未匹配 allow 的调用一律 deny",
      "bypassPermissions": "自动批准（deny/hook 仍生效）"
    },
    "rules": [
      { "action": "deny", "tool": "*", "pattern": "Bash(rm -rf *)" },
      { "action": "deny", "tool": "*", "pattern": "Bash(chmod 777 *)" },
      { "action": "deny", "tool": "*", "pattern": "Bash(:(){ :|:& };:)" },
      { "action": "deny", "tool": "read", "pattern": "/etc/shadow" },
      { "action": "deny", "tool": "read", "pattern": "/etc/passwd" },
      { "action": "deny", "tool": "edit", "pattern": "/proc/**" },
      { "action": "deny", "tool": "edit", "pattern": "/sys/**" },
      { "action": "deny", "tool": "edit", "pattern": "/dev/**" },
      { "action": "ask", "tool": "edit", "pattern": "**/.env" },
      { "action": "ask", "tool": "edit", "pattern": "**/*.key" },
      { "action": "ask", "tool": "bash", "pattern": "git push *" },
      { "action": "ask", "tool": "bash", "pattern": "npm publish *" },
      { "action": "allow", "tool": "read", "pattern": ".zero_apex/**" },
      { "action": "allow", "tool": "edit", "pattern": ".zero_apex/**" },
      { "action": "allow", "tool": "bash", "pattern": "Bash(ls *)" },
      { "action": "allow", "tool": "bash", "pattern": "Bash(cat *)" },
      { "action": "allow", "tool": "bash", "pattern": "Bash(git status)" },
      { "action": "allow", "tool": "bash", "pattern": "Bash(git log *)" },
      { "action": "allow", "tool": "bash", "pattern": "Bash(git diff *)" }
    ]
  }
}